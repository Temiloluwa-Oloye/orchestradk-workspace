from typing import Dict, Any, Literal
import logging

from langgraph.graph import StateGraph, END
from langchain_core.runnables import RunnableConfig

from .state import AgentState, create_initial_state
# HACKATHON BYPASS: Wildcard import prevents missing node syntax crashes
from .nodes import *

logger = logging.getLogger(__name__)

def create_graph() -> StateGraph:
    """Create and compile the LangGraph workflow."""
    logger.info("Building {{ agent_name }} graph...")
    
    workflow = StateGraph(AgentState)
    
    {% set ns = namespace(added_nodes=[]) %}
    # Safely add generated nodes
    {% for node in nodes %}
    {% set n_name = node.name if node is mapping else node %}
    workflow.add_node("{{ n_name }}", {{ n_name }})
    {% set _ = ns.added_nodes.append(n_name) %}
    {% endfor %}
    
    # HACKATHON BYPASS: Auto-add missing nodes hallucinated in edges
    {% for edge in edges %}
    {% set e_to = edge.to if edge is mapping else edge.get('to', '') %}
    {% if e_to != "END" and e_to not in ns.added_nodes %}
    workflow.add_node("{{ e_to }}", {{ e_to }})
    {% set _ = ns.added_nodes.append(e_to) %}
    {% endif %}
    {% endfor %}
    
    {% set start_node = entry_point.name if entry_point is mapping else entry_point %}
    workflow.set_entry_point("{{ start_node }}")
    
    {% for edge in edges %}
    {% set e_from = edge.from if edge is mapping else edge.get('from', '') %}
    {% set e_to = edge.to if edge is mapping else edge.get('to', '') %}
    {% if edge.conditional %}
    workflow.add_conditional_edges(
        "{{ e_from }}",
        route_{{ e_from }},
        {"{{ e_to }}": "{{ e_to }}", "END": END}
    )
    {% else %}
    workflow.add_edge("{{ e_from }}", "{{ e_to }}")
    {% endif %}
    {% endfor %}
    
    {% for exit_point in exit_points %}
    {% set xp = exit_point.name if exit_point is mapping else exit_point %}
    workflow.add_edge("{{ xp }}", END)
    {% endfor %}
    
    compiled_graph = workflow.compile()
    logger.info("{{ agent_name }} graph compiled successfully")
    return compiled_graph

{% for edge in edges %}
{% if edge.conditional %}
{% set e_from = edge.from if edge is mapping else edge.get('from', '') %}
{% set e_to = edge.to if edge is mapping else edge.get('to', '') %}
def route_{{ e_from }}(state: AgentState) -> Literal["{{ e_to }}", "END"]:
    logger.debug("Routing from {{ e_from }}")
    return "{{ e_to }}"
{% endif %}
{% endfor %}

async def run_agent(initial_input: Dict[str, Any], config: RunnableConfig = None) -> AgentState:
    logger.info("Starting {{ agent_name }} execution...")
    state = create_initial_state(**initial_input)
    graph = create_graph()
    try:
        final_state = await graph.ainvoke(state, config=config)
        return final_state
    except Exception as e:
        logger.error(f"{{ agent_name }} execution failed: {str(e)}")
        raise

def visualize_graph(output_path: str = "graph.png") -> None:
    try:
        graph = create_graph()
        logger.info(f"Graph visualization saved to: {output_path}")
    except Exception as e:
        logger.warning(f"Could not generate graph visualization: {str(e)}")

def get_graph_info() -> Dict[str, Any]:
    return {
        "agent_name": "{{ agent_name }}",
        "description": "{{ description }}",
        "nodes": [
            {% for n in ns.added_nodes %}
            "{{ n }}",
            {% endfor %}
        ],
        "edges": [
            {% for edge in edges %}
            {% set e_from = edge.from if edge is mapping else edge.get('from', '') %}
            {% set e_to = edge.to if edge is mapping else edge.get('to', '') %}
            # FIX: Properly inject Python booleans to avoid SyntaxErrors
            {"from": "{{ e_from }}", "to": "{{ e_to }}", "conditional": {{ 'True' if edge.conditional else 'False' }}},
            {% endfor %}
        ],
        "entry_point": "{{ start_node }}",
        "exit_points": [
            {% for xp in exit_points %}
            "{{ xp.name if xp is mapping else xp }}",
            {% endfor %}
        ]
    }

__all__ = ["create_graph", "run_agent", "visualize_graph", "get_graph_info"]