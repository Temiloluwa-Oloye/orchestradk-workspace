# watsonx Orchestrate Agent Configuration
# Generated by OrchestrADK

name: {{ agent_name }}
version: {{ version }}
description: {{ description }}

metadata:
  author: {{ author | default("OrchestrADK") }}
  created_at: {{ created_at }}
  framework: langgraph
  python_version: {{ python_version | default("3.10+") }}

runtime:
  type: python
  entry_point: {{ entry_point }}
  dependencies:
    - langgraph>=0.2.0
    - langchain>=0.3.0
    - pydantic>=2.0
    {% for dep in additional_dependencies %}
    - {{ dep }}
    {% endfor %}

agent:
  type: conversational
  capabilities:
    {% for capability in capabilities %}
    - {{ capability }}
    {% endfor %}
  
  state_schema:
    {% for field_name, field_info in state_fields.items() %}
    {{ field_name }}:
      type: {{ field_info.type }}
      description: {{ field_info.description }}
      required: {{ field_info.required | default(false) }}
    {% endfor %}

  nodes:
    {% for node in nodes %}
    - name: {{ node.name }}
      description: {{ node.description }}
      function: {{ node.function }}
      {% if node.inputs %}
      inputs:
        {% for input in node.inputs %}
        - {{ input }}
        {% endfor %}
      {% endif %}
      {% if node.outputs %}
      outputs:
        {% for output in node.outputs %}
        - {{ output }}
        {% endfor %}
      {% endif %}
    {% endfor %}

  workflow:
    entry_point: {{ workflow_entry_point }}
    {% if exit_points %}
    exit_points:
      {% for exit_point in exit_points %}
      - {{ exit_point }}
      {% endfor %}
    {% endif %}
    edges:
      {% for edge in edges %}
      - from: {{ edge.from }}
        to: {{ edge.to }}
        {% if edge.condition %}
        condition: {{ edge.condition }}
        {% endif %}
      {% endfor %}

integration:
  orchestrate:
    enabled: true
    skill_mapping: skills.yaml
    config: config.json