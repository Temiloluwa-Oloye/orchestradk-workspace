# watsonx Orchestrate Agent Configuration
# Generated by OrchestrADK

name: {{ agent_name | default('devops_agent') }}
version: {{ version | default('1.0.0') }}
description: {{ description | default('Intelligent DevOps support agent') }}

metadata:
  author: {{ author | default("OrchestrADK") }}
  created_at: {{ created_at | default("2026-05-03") }}
  framework: langgraph
  python_version: "3.10+"

runtime:
  type: python
  entry_point: {{ entry_point | default('main') }}
  dependencies:
    - langgraph>=0.2.0
    - langchain>=0.3.0
    - pydantic>=2.0

agent:
  type: conversational
  capabilities:
    - rag_search
    - script_generation
  
  state_schema:
    logs:
      type: string
      description: "User error logs"
      required: true

  nodes:
    - name: {{ entry_point | default('process_logs') }}
      description: "Analyze the error logs"
      function: "analyze_logs"

  workflow:
    entry_point: {{ entry_point | default('process_logs') }}
    exit_points:
      - generate_script
    edges:
      - from: {{ entry_point | default('process_logs') }}
        to: generate_script

integration:
  orchestrate:
    enabled: true
    skill_mapping: skills.yaml
    config: config.json